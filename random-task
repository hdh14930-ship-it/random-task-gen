import tkinter as tk
from tkinter import messagebox, simpledialog
import json
import random
import os

predefined_tasks = [
    {"task": "Прочитать статью", "type": "учёба"},
    {"task": "Сделать зарядку", "type": "спорт"},
    {"task": "Написать отчет", "type": "работа"},
    {"task": "Послушать музыку", "type": "развлечение"}
]

history_file = 'history.json'

def load_history():
    if os.path.exists(history_file):
        with open(history_file, 'r', encoding='utf-8') as f:
            return json.load(f)
    return []

def save_history(history):
    with open(history_file, 'w', encoding='utf-8') as f:
        json.dump(history, f, ensure_ascii=False, indent=4)

class RandomTaskGenerator:
    def __init__(self, master):
        self.master = master
        master.title("Random Task Generator")
        
        # Заголовки
        self.label = tk.Label(master, text="Нажмите 'Сгенерировать задачу'")
        self.label.pack(pady=10)
        
        # Кнопка генерации
        self.generate_button = tk.Button(master, text="Сгенерировать задачу", command=self.generate_task)
        self.generate_button.pack()
        
        # Фильтр
        self.filter_var = tk.StringVar()
        self.filter_var.set("Все")
        options = ["Все", "учёба", "спорт", "работа", "развлечение"]
        self.filter_menu = tk.OptionMenu(master, self.filter_var, *options, command=self.filter_tasks)
        self.filter_menu.pack(pady=5)
        
        # История задач
        self.history_listbox = tk.Listbox(master, width=50, height=10)
        self.history_listbox.pack(pady=10)
        
        # Ввод новой задачи
        self.add_task_button = tk.Button(master, text="Добавить задачу", command=self.add_task)
        self.add_task_button.pack(pady=5)
        
        # Загрузка истории при запуске
        self.history = load_history()
        self.update_history_display()
    
    def generate_task(self):
        task = random.choice(predefined_tasks)
        task_str = f"{task['task']} ({task['type']})"
        self.history.append(task)
        save_history(self.history)
        self.update_history_display()
        self.label.config(text=f"Случайная задача: {task_str}")
    
    def update_history_display(self, filter_type="Все"):
        self.history_listbox.delete(0, tk.END)
        for task in self.history:
            if filter_type == "Все" or task['type'] == filter_type:
                self.history_listbox.insert(tk.END, f"{task['task']} ({task['type']})")
    
    def filter_tasks(self, selected_filter):
        self.update_history_display(selected_filter)
    
    def add_task(self):
        task_text = simpledialog.askstring("Добавить задачу", "Введите задачу (формат: задача,тип):")
        if task_text:
            parts = task_text.split(",")
            if len(parts) == 2:
                task_name = parts[0].strip()
                task_type = parts[1].strip()
                if task_name and task_type:
                    new_task = {"task": task_name, "type": task_type}
                    predefined_tasks.append(new_task)
                    messagebox.showinfo("Успех", "Задача добавлена!")
                    # Обновим фильтр
                    self.filter_tasks(self.filter_var.get())
                else:
                    messagebox.showerror("Ошибка", "Пожалуйста, введите корректную задачу и тип.")
            else:
                messagebox.showerror("Ошибка", "Введите в формате: задача,тип")
        else:
            messagebox.showwarning("Предупреждение", "Пустая строка. Задача не добавлена.")

if __name__ == "__main__":
    root = tk.Tk()
    app = RandomTaskGenerator(root)
    root.mainloop()            
